# Copy to .env (gitignored). The model under test:
BASE_URL=https://api.deepseek.com/v1
BASE_KEY=sk-...
MODEL=deepseek-v4-flash
MODEL_MODE=tools             # tools = native function-calling; json = JSON-in-content (weak local models)
# MODEL_MAX_TOKENS=256000    # raise if you see "no_tool_call" (reasoning cut off before the tool call)
# MODEL_TEMPERATURE=0.3
# MODEL_NAME=my-label        # optional display name (defaults to MODEL)

# Named presets in balatro.config.json read their own keys from env vars, e.g.:
# OPENROUTER_API_KEY=sk-or-...

# Submit finished runs to a leaderboard backend (start it first). Empty = don't submit.
# SUBMIT_URL=http://localhost:3001
# SUBMITTER=your-handle
# SUBMIT=false               # opt out entirely (or pass --no-submit)

# Run shape (defaults live in balatro.config.json):
# SEED=BENCH01               # single seed — used by `live`, or a one-seed bench
# SEEDS=BENCH01,BENCH02      # seed list for the bench matrix
# RUNS_PER_SEED=1
# DECK=RED
# STAKE=WHITE

# Self-hosting the backend:
# BENCH_DB=bench/leaderboard.db   # give the server its own DB (separate from a local runner's bench.db)
# INGEST_KEY=...                  # require this on /ingest for public live-streaming
