{
  "name": "balatro-mcp",
  "version": "0.4.0",
  "type": "module",
  "description": "MCP server for controlling Balatro via balatrobot",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "start": "node dist/server.js",
    "mcp": "node dist/server.js",
    "live": "node dist/live.js",
    "bench": "node dist/bench/run.js",
    "bench:watch": "node dist/bench/run.js --watch",
    "leaderboard": "node dist/bench/leaderboard.js",
    "test:adapter": "node dist/llm/test-adapter.js",
    "test:score": "node dist/scoring/test-score.js",
    "test:setup": "node scripts/setup-local.test.mjs",
    "test": "node scripts/setup-local.test.mjs && node dist/llm/test-adapter.js && node dist/scoring/test-score.js",
    "probe": "node dist/llm/probe.js",
    "codehash": "node dist/scoring/print-codehash.js",
    "serve": "node dist/serve.js",
    "web:dev": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build",
    "setup": "npm --prefix web install && npm run build && npm run web:build",
    "setup:local": "node scripts/setup-local.mjs",
    "setup:check": "node scripts/setup-local.mjs --check",
    "setup:install": "node scripts/setup-local.mjs --install --yes",
    "setup:uninstall": "node scripts/setup-local.mjs --uninstall --yes"
  },
  "keywords": [
    "balatro",
    "mcp",
    "balatrobot"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "better-sqlite3": "^12.10.0",
    "undici": "^7.27.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
